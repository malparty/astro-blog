---
layout: base.njk
pagination:
  data: collections.categoryList
  size: 1
  alias: category
permalink: "/category/{{ category | slug }}/"
eleventyComputed:
  title: "Category: {{ category }}"
---
<h1>Category: {{ category }}</h1>
<ul class="post-list">
  {% for post in collections.posts %}
    {% if post.data.category == category %}
      <li>
        <a href="{{ post.url }}">{{ post.data.title }}</a>
        <span class="post-meta"><time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time></span>
      </li>
    {% endif %}
  {% endfor %}
</ul>
